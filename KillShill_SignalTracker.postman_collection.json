              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('signalId', json.data.id);",
                  "  console.log('Signal ID saved:', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
