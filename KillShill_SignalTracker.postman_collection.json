    {
      "name": "GET /api/signals — List All Signals",
      "item": [
        {
          "name": "Get All Signals",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/signals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signals"]
            },
            "description": "Returns all signals ordered by created_at descending.\n\n**Each signal includes:**\n- All stored fields\n- `current_price` — live Binance price (only for OPEN signals, null for resolved)\n- `roi` — calculated ROI to 2 decimal places\n\n**Status is auto-evaluated on every call:**\n- If an OPEN signal has hit target/stoploss/expired → status updated in DB\n- realized_roi saved permanently on resolution\n\n**Expected Response:** 200"
          },
          "response": [
            {
              "name": "200 — All Signals",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"symbol\": \"BTCUSDT\",\n      \"direction\": \"BUY\",\n      \"entry_price\": \"90000\",\n      \"stop_loss\": \"85000\",\n      \"target_price\": \"95000\",\n      \"entry_time\": \"2026-04-25T10:00:00.000Z\",\n      \"expiry_time\": \"2026-04-30T10:00:00.000Z\",\n      \"status\": \"OPEN\",\n      \"realized_roi\": null,\n      \"created_at\": \"2026-04-25T12:00:00.000Z\",\n      \"current_price\": 92500.45,\n      \"roi\": 2.78\n    }\n  ]\n}"
            }
          ]
        }
      ]
    },
