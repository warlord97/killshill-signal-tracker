generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Direction {
  BUY
  SELL
}

enum SignalStatus {
  OPEN
  TARGET_HIT
  STOPLOSS_HIT
  EXPIRED
}

model Signal {
  id           Int          @id @default(autoincrement())
  symbol       String
  direction    Direction
  entry_price  Decimal      @db.Decimal(20, 8)
  stop_loss    Decimal      @db.Decimal(20, 8)
  target_price Decimal      @db.Decimal(20, 8)
  entry_time   DateTime
  expiry_time  DateTime
  status       SignalStatus @default(OPEN)
  realized_roi Decimal?     @db.Decimal(10, 2)
  created_at   DateTime     @default(now())
}